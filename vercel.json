{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/seo?type=robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo?type=sitemap"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "30 2 * * *"
    }
  ]
}
