{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    },
    {
      "src": "app-data.js",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/seo?type=robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo?type=sitemap"
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "30 2 * * *"
    }
  ]
}
