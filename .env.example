PORT=3000
BASE_URL=http://127.0.0.1:3000
USE_SUPABASE_STORAGE=0
ADMIN_PASSWORD=

# OpenRouter: create at https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Pexels: create at https://www.pexels.com/api/
PEXELS_API_KEY=

# Supabase: create at https://supabase.com/ from Project Settings > API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Vercel cron auth secret: set the same value in Vercel Project Settings > Environment Variables
CRON_SECRET=
